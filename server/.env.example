# Backend environment variables
# Copy this file to server/.env for local overrides (optional — defaults work for dev).

PORT=3001
NODE_ENV=development

# REQUIRED in production — generate with: openssl rand -hex 32
JWT_SECRET=

# Allowed frontend origin for CORS.
# Dev default: http://localhost:5173 (set automatically when FRONTEND_URL is unset)
# Production: set to your Vercel URL, e.g. https://taskflow-xyz.vercel.app
FRONTEND_URL=

# SQLite database file path.
# Dev default: server/taskflow.db (set automatically when DB_PATH is unset)
# Production on Render with a persistent disk: /data/taskflow.db
DB_PATH=
