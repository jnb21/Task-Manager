# Backend environment variables
# Copy this file to server/.env for local overrides (optional — defaults work for dev).

PORT=3001
NODE_ENV=development

# REQUIRED in production — generate with: openssl rand -hex 32
JWT_SECRET=

# Allowed frontend origin for CORS.
# Dev default: http://localhost:5173 (set automatically when FRONTEND_URL is unset)
# Production: set to your Vercel URL, e.g. https://taskflow-xyz.vercel.app
FRONTEND_URL=

# Turso database (serverless SQLite).
# Dev default: uses a local file (server/taskflow.db) when TURSO_URL is unset.
# Production: get these from https://turso.tech after creating a database.
#   turso db create taskflow
#   turso db show taskflow --url    → TURSO_URL
#   turso db tokens create taskflow → TURSO_TOKEN
TURSO_URL=
TURSO_TOKEN=
